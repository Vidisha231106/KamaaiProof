# KamaaiProof AI Engine — Environment Variables
# Copy this to .env and fill in values.

# Server config
HOST=0.0.0.0
PORT=8000

# CORS: comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenClaw API key (placeholder — not used in mock mode)
OPENCLAW_API_KEY=

# Encryption key (placeholder — not used in mock mode)
ENCRYPTION_KEY=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
